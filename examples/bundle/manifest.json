{
  "name": "moon-mustache-bundle-demo",
  "context": {
    "project": {
      "network": "moon-mustache-net"
    }
  },
  "partials": {
    "footer": "# Generated by moon-mustache\n",
    "feature_list": "{{#features}}- {{.}}\n{{/features}}"
  },
  "profiles": {
    "dev": {
      "context": {
        "project": {
          "port": 3000
        }
      }
    },
    "prod": {
      "context": {
        "project": {
          "port": 8080
        }
      },
      "partials": {
        "footer": "# Generated for production\n"
      }
    }
  },
  "files": [
    {
      "path": ".env",
      "template": "APP_NAME={{project.name}}\nAPP_PORT={{project.port}}\nOWNER={{owner.name}}\n{{> footer}}"
    },
    {
      "path": "README.generated.md",
      "template": "# {{project.name}}\n\nMaintainer: {{owner.name}}\n\n## Features\n{{> feature_list}}{{> footer}}"
    },
    {
      "path": "deploy/config.toml",
      "template": "service = \"{{project.name}}\"\nport = {{project.port}}\n"
    }
  ]
}
