{
  "name": "moon-mustache-playground",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "moon-engine": "node scripts/build-moon-engine.mjs",
    "predev": "npm run moon-engine",
    "dev": "vite --host",
    "prebuild": "npm run moon-engine",
    "build": "vite build",
    "preview": "vite preview --host",
    "api": "node server.mjs",
    "smoke": "node smoke.mjs",
    "test:evidence": "node --test scripts/evidence.test.mjs",
    "test:differential-minimizer": "node --test scripts/differential-minimizer.test.mjs scripts/differential-pipeline.test.mjs",
    "differential": "npm run moon-engine && node scripts/differential-test.mjs --cases-per-seed 1536 --seeds 20260710,20260711,20260712,20260713"
  },
  "dependencies": {
    "mustache": "^4.2.0",
    "vue": "^3.5.18"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.8",
    "concurrently": "^9.2.4",
    "vite": "^8.1.5"
  }
}
