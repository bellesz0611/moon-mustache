    #|    {
    #|      "path": "content/{{release.slug}}/overview.md",
    #|      "template": "# {{release.name}}\n\nAudience: {{audience_label}}\n\n## Features\n{{> feature_cards}}{{> footer}}"
    #|    },
    #|    {
    #|      "path": "content/{{release.slug}}/announcement.txt",
    #|      "template": "Subject: {{release.name}} is live\n\nHello {{audience_label}} readers,\n\n{{> feature_cards}}{{> footer}}"
    #|    },
    #|    {
    #|      "path": "content/{{release.slug}}/card.html",
    #|      "template": "<section><h1>{{release.name}}</h1><ul>{{#features}}<li><strong>{{title}}</strong>: {{summary}}</li>{{/features}}</ul></section>"
    #|    }
    #|  ]
    #|}
  manifest
}

///|
fn content_context() -> @src.Value {
  @src.Value::object({
    "release": @src.Value::object({
      "name": @src.Value::string("Moon Mustache 0.1.0"),
      "slug": @src.Value::string("moon-mustache-0-1-0"),
    }),
    "features": @src.Value::array([
      @src.Value::object({
        "title": @src.Value::string("Spec parity"),
        "summary": @src.Value::string("136 official fixture cases passing"),
      }),
      @src.Value::object({
        "title": @src.Value::string("Bundle planning"),
        "summary": @src.Value::string("multi-file validation and plan reporting"),
      }),
      @src.Value::object({
        "title": @src.Value::string("Playground"),
        "summary": @src.Value::string("browser-facing MoonBit-powered demo"),
      }),
    ]),
  })
}

///|
fn print_file(path : String, output : String) -> Unit {
  println("== " + path + " ==")
  println(output)
  println("")
}

///|
fn main {
  let manifest = @src.parse_bundle_manifest_json(content_manifest_json()).unwrap()
  let validation = @src.validate_bundle_manifest(manifest)
  let result = @src.render_bundle_manifest_checked(
    manifest,
    content_context(),
    @src.RenderOptions::strict(),
    profile_name="partners",
  ).unwrap()
  let plan = @src.build_bundle_plan("content-pipeline-kit", result, validation)

  println(@src.format_validation_report_markdown("content-pipeline-kit", validation))
  println("")
  println(@src.format_bundle_plan_markdown(plan))
  println("")

  for file in result.files {
    print_file(file.path, file.output)
  }
}
