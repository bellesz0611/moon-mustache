  let manifest =
    #|{
    #|  "name": "content-pipeline-kit",
    #|  "partials": {
    #|    "feature_cards": "{{#features}}- {{title}}: {{summary}}\n{{/features}}",
    #|    "footer": "Generated by Moon Mustache content pipeline.\n"
    #|  },
    #|  "profiles": {
