///|
fn starter_context() -> @src.Value {
  @src.Value::object({
    "project": @src.Value::object({
      "name": @src.Value::string("moon-starter-kit"),
      "slug": @src.Value::string("moon-starter-kit"),
      "owner": @src.Value::string("moonbit-community"),
      "repository": @src.Value::string(
        "https://github.com/moonbit-community/moon-starter-kit",
      ),
    }),
    "modules": @src.Value::array([
      @src.Value::string("CLI"),
      @src.Value::string("CI workflow"),
      @src.Value::string("Formatting and test gates"),
    ]),
  })
}

///|
fn print_file(path : String, output : String) -> Unit {
  println("== " + path + " ==")
  println(output)
  println("")
}

///|
fn main {
  let manifest = @src.parse_bundle_manifest_json(starter_manifest_json()).unwrap()
  let validation = @src.validate_bundle_manifest(manifest)
  let result = @src.render_bundle_manifest_checked(
    manifest,
    starter_context(),
    @src.RenderOptions::strict(),
    profile_name="template",
  ).unwrap()
  let plan = @src.build_bundle_plan("starter-repo-kit", result, validation)

  println(@src.format_validation_report_markdown("starter-repo-kit", validation))
  println("")
  println(@src.format_bundle_plan_markdown(plan))
  println("")

  for file in result.files {
    print_file(file.path, file.output)
  }
}
