///|
pub struct OfficialSpecCase {
  suite_name : String
  case_name : String
  description : String
  template : String
  data_json : String
  partials_json : String
  expected_output : String
  run_in_ci : Bool
  skip_reason : String?
}

///|
pub fn official_spec_cases() -> Array[OfficialSpecCase] {
